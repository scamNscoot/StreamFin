<brls:Box
    width="auto"
    height="auto"
    paddingLeft="@style/main/content_padding_sides"
    paddingRight="@style/main/content_padding_sides"
    paddingBottom="@style/main/content_padding_top_bottom">

    <AutoTabFrame
        id="dashboard/tabFrame"
        grow="1"
        defaultTab="0"
        tabHeight="60"
        tabItemActiveTextColor="@theme/color/app"
        sidebarPosition="top">

        <Tab label="@i18n/main/tabs/home">
            <brls:Box>
                <brls:Box
                    grow="1"
                    id="dashboard/main/box"
                    axis="column">

                    <brls:Box
                        backgroundColor="@theme/color/grey_2"
                        width="100%"
                        height="150"
                        padding="30"
                        justifyContent="center"
                        axis="column">

                        <brls:Box>
                            <brls:Label width="150"
                                text="@i18n/main/setting/server/header" />
                            <brls:Label id="dashboard/server/version" text="-" />
                        </brls:Box>

                        <brls:Box
                            marginTop="15">
                            <brls:Label width="150"
                                text="@i18n/main/setting/name" />
                            <brls:Label id="dashboard/server/name" text="-" />
                        </brls:Box>

                        <brls:Box
                            marginTop="15">
                            <brls:Label width="150"
                                text="@i18n/main/setting/network/host" />
                            <brls:Label id="dashboard/server/addr" text="-" />
                        </brls:Box>

                    </brls:Box>

                    <HRecyclerFrame
                        marginTop="20"
                        height="50"
                        itemSpace="10"
                        itemWidth="160"
                        id="dashboard/count" />

                    <RecyclingGrid
                        grow="1.0"
                        marginTop="20"
                        wireframe="false"
                        spanCount="@style/app/grid/2"
                        itemSpace="10"
                        itemHeight="180"
                        id="dashboard/session" />

                </brls:Box>

                <RecyclingGrid
                    width="300"
                    marginLeft="20"
                    marginRight="10"
                    wireframe="false"
                    spanCount="1"
                    itemSpace="10"
                    itemHeight="120"
                    id="dashboard/activity" />

                <brls:Box
                    width="250"
                    axis="column">
                    <brls:Button
                        id="dashboard/scan"
                        text="@i18n/main/dashboard/scan_all"
                        marginBottom="15" />

                    <brls:Button
                        id="dashboard/restart"
                        text="@i18n/main/dashboard/restart" />

                    <brls:Box
                        marginTop="20"
                        grow="1.0"
                        id="dashboard/storage/box"
                        axis="column">
                    </brls:Box>
                </brls:Box>

            </brls:Box>
        </Tab>
    </AutoTabFrame>

    <ButtonClose
        positionType="absolute"
        positionTop="2"
        positionRight="2" />

</brls:Box>