<brls:Box
    width="auto"
    height="auto">

    <!-- centered : le scroll suit le focus D-pad (boutons -> casting -> rangées) -->
    <brls:ScrollingFrame
        grow="1.0"
        scrollingBehavior="centered">

        <brls:Box
            axis="column"
            paddingBottom="@style/main/content_padding_top_bottom">

            <brls:Box
                id="movie/banner"
                width="100%"
                height="320">
                <brls:Image
                    id="movie/image/backdrop"
                    width="100%"
                    height="100%"
                    scalingType="fill"
                    cornerRadius="4"
                    backgroundColor="@theme/color/grey_1" />
                <brls:Image
                    id="movie/banner/fade"
                    positionType="absolute"
                    positionBottom="0"
                    positionLeft="0"
                    width="100%"
                    height="260"
                    scalingType="stretch"
                    image="@res/img/fade-bottom-dark.png" />
                <brls:Box
                    positionType="absolute"
                    positionBottom="26"
                    positionLeft="0"
                    width="100%"
                    justifyContent="center">
                    <brls:Image
                        id="movie/image/logo"
                        width="440"
                        height="120"
                        scalingType="fit" />
                </brls:Box>
            </brls:Box>

            <brls:Box
                id="movie/content/row"
                marginTop="-150"
                paddingLeft="@style/main/content_padding_sides"
                paddingRight="@style/main/content_padding_sides">

                <brls:Box
                    width="220"
                    axis="column"
                    marginTop="64"
                    marginRight="34">
                    <brls:Image
                        id="movie/image/poster"
                        height="330"
                        scalingType="fill"
                        cornerRadius="10"
                        backgroundColor="@theme/color/grey_1"
                        image="@res/img/video-card-bg.png" />

                    <brls:SelectorCell
                        id="movie/source"
                        visibility="gone"
                        height="40"
                        marginTop="20px" />
                </brls:Box>

                <brls:Box
                    id="movie/content/info"
                    axis="column"
                    marginTop="184"
                    grow="1.0">

                    <brls:Label
                        id="movie/label/title"
                        fontSize="42"
                        marginBottom="14" />

                    <brls:Box
                        alignItems="center"
                        marginBottom="14">

                        <brls:Box
                            cornerRadius="14"
                            height="28"
                            alignItems="center"
                            paddingLeft="12"
                            paddingRight="12"
                            marginRight="8"
                            backgroundColor="@theme/color/pill">
                            <brls:Label
                                id="movie/label/year"
                                singleLine="true"
                                fontSize="14" />
                        </brls:Box>

                        <brls:Box
                            cornerRadius="14"
                            height="28"
                            alignItems="center"
                            paddingLeft="12"
                            paddingRight="12"
                            marginRight="8"
                            visibility="gone"
                            backgroundColor="@theme/color/pill">
                            <brls:Label
                                id="movie/parental/rating"
                                singleLine="true"
                                fontSize="14" />
                        </brls:Box>

                        <brls:Box
                            cornerRadius="14"
                            height="28"
                            alignItems="center"
                            paddingLeft="12"
                            paddingRight="12"
                            visibility="gone"
                            backgroundColor="@theme/color/pill">
                            <SVGImage
                                width="14"
                                height="14"
                                marginRight="5"
                                svg="@res/icon/ico-star.svg" />
                            <brls:Label
                                id="movie/label/rating"
                                singleLine="true"
                                fontSize="14" />
                        </brls:Box>
                    </brls:Box>

                    <brls:Label
                        id="movie/label/genres"
                        fontSize="14"
                        animated="false"
                        textColor="@theme/font/grey"
                        marginBottom="16" />

                    <brls:Box
                        id="movie/buttons"
                        axis="row"
                        marginBottom="18">

                        <IconButton
                            id="movie/play"
                            icon="@res/icon/ico-play-dark.svg"
                            text="@i18n/main/media/play"
                            buttonStyle="primary" />

                        <IconButton
                            id="movie/download"
                            icon="@res/icon/ico-download-light.svg"
                            text="@i18n/main/download/start"
                            buttonStyle="bordered"
                            marginLeft="12" />
                    </brls:Box>

                    <TextBox
                        id="movie/label/overview"
                        fontSize="15"
                        textColor="@theme/font/grey" />

                </brls:Box>
            </brls:Box>

            <brls:Header
                marginTop="28"
                marginBottom="6"
                marginLeft="@style/main/content_padding_sides"
                marginRight="@style/main/content_padding_sides"
                id="movie/label/people"
                title="@i18n/main/media/people" />

            <HRecyclerFrame
                height="250"
                itemWidth="140"
                itemSpace="18"
                marginBottom="28"
                paddingLeft="@style/main/content_padding_sides"
                paddingRight="@style/main/content_padding_sides"
                id="movie/people" />

            <brls:Header
                marginBottom="6"
                marginLeft="@style/main/content_padding_sides"
                marginRight="@style/main/content_padding_sides"
                id="movie/label/similar"
                title="@i18n/main/media/similar" />

            <HRecyclerFrame
                height="250"
                itemWidth="140"
                itemSpace="18"
                marginBottom="28"
                paddingLeft="@style/main/content_padding_sides"
                paddingRight="@style/main/content_padding_sides"
                id="movie/similar" />

        </brls:Box>

    </brls:ScrollingFrame>
</brls:Box>