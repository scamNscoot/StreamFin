<brls:Box
    width="auto"
    height="auto"
    justifyContent="flexEnd"
    backgroundColor="@theme/brls/backdrop">

    <brls:Box
        id="video/cancel"
        height="100%"
        hideClickAnimation="true"
        grow="1" />

    <brls:Box
        id="video/context/menu"
        width="400"
        height="100%"
        axis="column"
        paddingTop="24"
        paddingBottom="24"
        paddingLeft="18"
        paddingRight="18"
        backgroundColor="@theme/color/surface"
        alignItems="stretch">

        <brls:Label
            id="menu/title"
            fontSize="21"
            marginLeft="10"
            marginBottom="14" />

        <MenuItem
            icon="@res/icon/ico-heart.svg"
            title="@i18n/main/media/add_favorite"
            id="menu/favorite" />
        <MenuItem
            icon="@res/icon/ico-checkmark.svg"
            title="@i18n/main/media/mark_played"
            id="menu/mark/play" />
        <MenuItem
            icon="@res/icon/ico-download.svg"
            title="@i18n/main/download/start"
            id="menu/download" />

    </brls:Box>
</brls:Box>