<brls:Box
    highlightCornerRadius="8"
    backgroundColor="@theme/color/grey_2"
    axis="column"
    padding="20"
    justifyContent="spaceBetween">

    <brls:Label
        id="activity/time"
        fontSize="16" />
    <brls:Label
        id="activity/name"
        singleLine="true" />

    <brls:Box justifyContent="spaceBetween">
        <brls:Label
            textColor="@theme/font/grey"
            singleLine="true"
            fontSize="16"
            id="activity/overview" />
        <brls:Label
            textColor="@theme/font/grey"
            fontSize="16"
            id="activity/type" />
    </brls:Box>
</brls:Box>