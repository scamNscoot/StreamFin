<brls:Box
    highlightCornerRadius="8"
    alignItems="center"
    backgroundColor="@theme/color/grey_2"
    padding="10">

    <brls:Label
        id="device/time"
        width="250" />

    <brls:Label
        id="device/name"
        grow="1.0" />

    <brls:Label
        id="device/app"
        width="300" />

    <brls:Image
        id="device/avatar"
        width="40"
        height="40"
        marginRight="10"
        image="@res/img/account.png"
        cornerRadius="10" />
    <brls:Label
        id="device/user"
        width="200" />

</brls:Box>