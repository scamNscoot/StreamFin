# Maintainer: cpasjuste <cpasjuste@gmail.com>

# With c-ares, curl can using custom DNS server,
# You can also use musl with custom DNS support to do similar things (Recommended)

pkgname=ps4-openorbis-dav1d
pkgver=1.5.3
pkgrel=1
pkgdesc='AV1 cross-platform decoder focused on speed and correctness'
arch=('any')
url='https://code.videolan.org/videolan/dav1d'
license=('curl')
source=("https://downloads.videolan.org/pub/videolan/dav1d/${pkgver}/dav1d-${pkgver}.tar.xz" 'cross.txt')
sha256sums=('732010aa5ef461fa93355ed2c6c5fedb48ddc4b74e697eaabe8907eaeb943011' 'SKIP')
options=(!strip !debug libtool staticlibs)
depends=('ps4-openorbis-zlib' 'ps4-openorbis-mbedtls')
makedepends=('ps4-openorbis-vars')
groups=('ps4-openorbis-portlibs')

build() {
  source /opt/pacbrew/ps4/openorbis/ps4vars.sh
  meson setup build dav1d-${pkgver} \
    --buildtype=plain --cross-file=cross.txt \
    --default-library=static --libdir=lib \
    --prefix="${OPENORBIS}/usr" \
    -Denable_tests=false \
    -Denable_docs=false \
    -Denable_tools=false \
    -Denable_examples=false
  meson compile -C build
}

package() {
  meson install -C build --destdir "${pkgdir}"
}
